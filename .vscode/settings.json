{
  // ── Archivos ──
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "off",

  // ── Editor general ──
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.autoIndent": "none",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.linkedEditing": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,
  "editor.stickyScroll.enabled": true,
  "editor.fontLigatures": true,
  "editor.renderWhitespace": "all",
  "editor.renderControlCharacters": true,
  "editor.unicodeHighlight.ambiguousCharacters": true,
  "editor.unicodeHighlight.invisibleCharacters": true,
  "editor.unicodeHighlight.nonBasicASCII": true,
  // ── Autocompletado DESACTIVADO ──
  "editor.suggestOnTriggerCharacters": false,
  "editor.quickSuggestions": {
    "strings": false,
    "comments": false,
    "other": false
  },
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.parameterHints.enabled": false,
  "editor.wordBasedSuggestions": "off",
  "editor.snippetSuggestions": "none",

  // ── Teclado / accesibilidad ──
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.emptySelectionClipboard": false,

  // ── JavaScript ──
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ── Visibilidad: evitar texto blanco invisible ──
  "workbench.colorCustomizations": {
    "editor.foreground": "#d4d4d4",
    "editor.background": "#1e1e1e",
    "terminal.foreground": "#d4d4d4",
    "terminal.background": "#1e1e1e",
    "terminal.ansiWhite": "#d4d4d4",
    "terminal.ansiBrightWhite": "#ffffff",
    "editorWhitespace.foreground": "#3b3b3b"
  },
  "editor.colorDecoratorsLimit": 500,

  // ── Terminal ──
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.smoothScrolling": true,

  // ── Protección: archivos de configuración SOLO LECTURA ──
  "files.readonlyInclude": {
    ".vscode/settings.json": true,
    ".vscode/launch.json": true,
    ".vscode/tasks.json": true,
    ".vscode/extensions.json": true,
    ".vscode/keybindings.json": true,
    ".editorconfig": true,
    ".gitignore": true
  }
}
